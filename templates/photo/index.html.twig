{% extends 'base.html.twig' %}

{% block title %}Focus Gallery{% endblock %}

{% block body %}
    <div class="container py-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="mb-0">gallery</h1>
            <span class="text-body-secondary">{{ photos|length }} photos</span>
        </div>

        <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 row-cols-xl-4 g-4">
            {% for photo in photos %}
                <div class="col">
                    <div class="card h-100 shadow-sm border-0">
                        <img
                            src="/images/photos/{{ photo.imageName }}"
                            class="card-img-top"
                            alt="{{ photo.imageName }}"
                            style="height: 220px; object-fit: cover;"
                        >
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">{{ photo.title }}</h5>

                            <p class="card-text text-body-secondary small">
                                {{ photo.description|slice(0, 90) }}{% if photo.description|length > 90 %}...{% endif %}
                            </p>

                            

                                <a href="{{ path('app_photo_show', {'id': photo.id}) }}" class="btn btn-outline-primary w-100">
                                    Voir la photo
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="col-12">
                    <div class="alert alert-warning mb-0">
                        Aucune image trouvé.
                    </div>
                </div>
            {% endfor %}
        </div>
    </div>
{% endblock %}
